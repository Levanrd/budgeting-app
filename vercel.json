{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://budgeting-app-api-3zzy.onrender.com/api/$1"
    },
    {
      "source": "/((?!api/|assets/|favicon.ico|vite.svg).*)",
      "destination": "/index.html"
    }
  ]
}
