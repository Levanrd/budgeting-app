PORT=3000
# Include the database name in the URI (e.g. .../budgeting-app) so data is saved where you expect.
# Atlas: mongodb+srv://user:pass@cluster.xxx.mongodb.net/budgeting-app?retryWrites=true
MONGODB_URI=mongodb://localhost:27017/budgeting-app
# Optional: if your URI has no database path, set this so the app uses a named database
# MONGODB_DB_NAME=budgeting-app
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CORS_ORIGIN=http://localhost:5173
APP_TIMEZONE=Asia/Manila
NODE_ENV=development
SEED_USERS=false
